if [ "$(id -u)" != "0" ]; then
	echo -e "You need to be root to run this command...\n"
	exit 1
fi

exec 200>/var/lock/pistar-upgrade.lock || exit 1
if ! flock -n 200 ; then
	echo -e "Another instance is already running...\n"
	exit 1
fi

deploy_sudoers_tightening() {
	# Build /etc/sudoers.d/pistar-dashboard line by line and validate
	# it via visudo -c against a /tmp staging file BEFORE installing.
	# Order of operations is critical: the new file must be installed
	# and validated before we remove the open "NOPASSWD: ALL" line
	# from /etc/sudoers, so an interrupted run can never strand
	# www-data without any sudo path. If anything fails visudo -c,
	# both halves are rolled back before this function returns 1.

	stage=/tmp/pistar-dashboard.sudoers
	target=/etc/sudoers.d/pistar-dashboard

	echo '#'                                                                                                                                                          >  ${stage}
	echo '# Path-scoped allowlist for the Pi-Star Dashboard www-data process.'                                                                                        >> ${stage}
	echo '# Replaces the previous "www-data ALL=(ALL) NOPASSWD: ALL" in /etc/sudoers.'                                                                                >> ${stage}
	echo '# Deployed by pistar-upgrade.'                                                                                                                              >> ${stage}
	echo '#'                                                                                                                                                          >> ${stage}
	echo ''                                                                                                                                                           >> ${stage}
	echo 'Defaults!PISTAR_DASH_ALL !requiretty'                                                                                                                       >> ${stage}
	echo ''                                                                                                                                                           >> ${stage}
	echo ''                                                                                                                                                           >> ${stage}
	echo '# ------------------------------------------------------------------'                                                                                       >> ${stage}
	echo '# Service control'                                                                                                                                          >> ${stage}
	echo '# ------------------------------------------------------------------'                                                                                       >> ${stage}
	echo 'Cmnd_Alias PISTAR_DASH_SYSTEMCTL = \'                                                                                                                       >> ${stage}
	echo '    /bin/systemctl daemon-reload, \'                                                                                                                        >> ${stage}
	echo '    /bin/systemctl start  aprsgateway.service,    /bin/systemctl stop aprsgateway.service,    /bin/systemctl restart aprsgateway.service, \'                >> ${stage}
	echo '    /bin/systemctl start  dapnetgateway.service,  /bin/systemctl stop dapnetgateway.service,  /bin/systemctl restart dapnetgateway.service, \'              >> ${stage}
	echo '    /bin/systemctl start  dmr2nxdn.service,       /bin/systemctl stop dmr2nxdn.service, \'                                                                  >> ${stage}
	echo '    /bin/systemctl start  dmr2ysf.service,        /bin/systemctl stop dmr2ysf.service, \'                                                                   >> ${stage}
	echo '    /bin/systemctl start  dmrgateway.service,     /bin/systemctl stop dmrgateway.service,     /bin/systemctl restart dmrgateway.service, \'                 >> ${stage}
	echo '    /bin/systemctl start  dstarrepeater.service,  /bin/systemctl stop dstarrepeater.service,  /bin/systemctl restart dstarrepeater.service, \'              >> ${stage}
	echo '    /bin/systemctl start  ircddbgateway.service,  /bin/systemctl stop ircddbgateway.service,  /bin/systemctl restart ircddbgateway.service, \'              >> ${stage}
	echo '    /bin/systemctl start  m17gateway.service,     /bin/systemctl stop m17gateway.service,     /bin/systemctl restart m17gateway.service, \'                 >> ${stage}
	echo '    /bin/systemctl start  mmdvmhost.service,      /bin/systemctl stop mmdvmhost.service,      /bin/systemctl restart mmdvmhost.service, \'                  >> ${stage}
	echo '    /bin/systemctl start  mobilegps.service,      /bin/systemctl stop mobilegps.service, \'                                                                 >> ${stage}
	echo '    /bin/systemctl start  nxdn2dmr.service,       /bin/systemctl stop nxdn2dmr.service, \'                                                                  >> ${stage}
	echo '    /bin/systemctl start  nxdngateway.service,    /bin/systemctl stop nxdngateway.service,    /bin/systemctl restart nxdngateway.service, \'                >> ${stage}
	echo '    /bin/systemctl start  nxdnparrot.service,     /bin/systemctl stop nxdnparrot.service, \'                                                                >> ${stage}
