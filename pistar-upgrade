	echo '    /usr/local/sbin/pistar-factory-reset --really, \'                                                                                                       >> ${stage}
	echo '    /usr/local/bin/remotecontrold *, \'                                                                                                                     >> ${stage}
	echo '    /usr/local/bin/RemoteCommand *'                                                                                                                         >> ${stage}
	echo ''                                                                                                                                                           >> ${stage}
	echo 'Cmnd_Alias PISTAR_DASH_ALL = \'                                                                                                                             >> ${stage}
	echo '    PISTAR_DASH_SYSTEMCTL,    PISTAR_DASH_MOUNT,        PISTAR_DASH_INSTALL, \'                                                                             >> ${stage}
	echo '    PISTAR_DASH_CP_STAGE,     PISTAR_DASH_STAGE_PERMS,  PISTAR_DASH_LOGS, \'                                                                                >> ${stage}
	echo '    PISTAR_DASH_MARKERS,      PISTAR_DASH_SED,          PISTAR_DASH_READ_PRIV, \'                                                                           >> ${stage}
	echo '    PISTAR_DASH_PASSWD,       PISTAR_DASH_NETWORK,      PISTAR_DASH_TIME, \'                                                                                >> ${stage}
	echo '    PISTAR_DASH_POWER,        PISTAR_DASH_BACKUP,       PISTAR_DASH_MISC, \'                                                                                >> ${stage}
	echo '    PISTAR_DASH_SCRIPTS'                                                                                                                                    >> ${stage}
	echo ''                                                                                                                                                           >> ${stage}
	echo 'www-data ALL=(root) NOPASSWD: PISTAR_DASH_ALL'                                                                                                              >> ${stage}

	# Validate the staged spec before letting it anywhere near
	# /etc/sudoers.d/. visudo -c parses and rejects bad syntax.
	if ! visudo -c -f ${stage} >/dev/null 2>&1; then
		echo "[!] ERROR: staged sudoers.d/pistar-dashboard failed visudo -c"
		rm -f ${stage}
		return 1
	fi

	# Install with the conventional sudoers mode 0440 root:root
	install -m 440 -o root -g root ${stage} ${target}
	rm -f ${stage}

	# Re-validate the merged sudoers state with the new file in place
	# but the open NOPASSWD: ALL line still present. Should pass; if it
	# does not, the new file is malformed in a way visudo missed in -f
	# mode (very unlikely) - roll back.
	if ! visudo -c >/dev/null 2>&1; then
		echo "[!] ERROR: merged sudoers state invalid after installing ${target}; rolling back"
		rm -f ${target}
		return 1
	fi

	# Remove the open www-data NOPASSWD: ALL line from /etc/sudoers.
	# Pattern is anchored to start and end of line so it cannot
	# accidentally remove a substring of another rule.
	sed -i '/^www-data ALL=(ALL) NOPASSWD: ALL$/d' /etc/sudoers

	# Validate again with the line removed. If the merged state somehow
	# fails now, restore both halves so www-data is not stranded.
	if ! visudo -c >/dev/null 2>&1; then
		echo "[!] ERROR: sudoers state invalid after removing the NOPASSWD: ALL line; rolling back"
		grep -q '^www-data ALL=(ALL) NOPASSWD: ALL$' /etc/sudoers || \
			echo 'www-data ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers
		rm -f ${target}
		return 1
	fi

	return 0
}

main_function() {
	echo "[INFO] Pi-Star Upgrade process starting..."
	# Get the current Modem
	if [ -f /etc/dstar-radio.mmdvmhost ]; then
		pistarModem=$(awk -F "=" '/Hardware/ {print $2}' /etc/dstar-radio.mmdvmhost)
	elif [ -f /etc/dstar-radio.dstarrepeater ]; then
		pistarModem=$(awk -F "=" '/Hardware/ {print $2}' /etc/dstar-radio.dstarrepeater)
	else
		pistarModem=Unknown
	fi

	# Get the Pi-Star Version Info
	pistarCurVersion=$(awk -F "= " '/Version/ {print $2}' /etc/pistar-release)
	# Get the hardware type, this may be important later (RPi | NanoPi | OdroidXU4)
	pistarHardware=$(awk -F "= " '/Hardware/ {print $2}' /etc/pistar-release)

	# Make the disk writable
	if [ -d /boot/firmware ]; then
